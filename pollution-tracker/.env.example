# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# Leave blank to run in MOCK classification mode (no Gemini key needed).
# Get a free key at aistudio.google.com -> "Get API key".
GEMINI_API_KEY=

# Only needed if running the API OUTSIDE Docker (e.g. `uvicorn` directly
# on your laptop). Inside Docker Compose, this is overridden automatically
# to point at the `db` service.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pollution_tracker
